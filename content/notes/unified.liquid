<!doctype html>
<html>
  <head>
    <title>{{ title }}</title>
    <link rel="stylesheet" href="{{ '/style.css' | url }}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
      const toggleSidebar = (open) => {
        if (!open) {
          document.getElementById('overlay').className = 'fixed inset-0 bg-gray-900/80 lg:hidden hidden';
          document.getElementById('menu').className = 'fixed inset-0 flex flex-col hidden lg:block lg:static';
          open = false;
        } else {
          document.getElementById('overlay').className = 'fixed inset-0 bg-gray-900/80 lg:hidden';
          document.getElementById('menu').className = 'fixed inset-0 flex flex-col  lg:block lg:static';
          open = true;
        }
      };
    </script>
  </head>
  <body class="font-sans leading-normal tracking-normal">
    <div class="min-h-screen bg-red-100 flex flex-col lg:flex-row">
      <div class="lg:hidden flex">
        <div onClick="toggleSidebar(true)">hamburger</div>
        mobile Title
      </div>
      <div id="overlay" class="fixed inset-0 bg-gray-300/90 hidden lg:hidden "></div>
      <div id="menu" class="fixed inset-0 flex flex-col hidden lg:block lg:static">
        <div class="flex flex-col min-h-screen">
          <div class="hidden lg:block ">desktop Title</div>
          <div class="flex flex-1">
            <div class="w-16 bg-green-200">dots</div>
            <div class="w-64 bg-green-300">Folders</div>
            <div class="bg-transparent lg:hidden">
              <button class="text-white" onClick="toggleSidebar(false)">close</button>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-blue-100 flex-1">
        ContentContentContentContentContentContentContentContentContent
        ContentContentContentContentContentContentContentContentContent
        ContentContentContentContentContentContentContentContentContent
        ContentContentContentContentContentContentContentContentContent ContentContentContentContentContent
      </div>
    </div>
  </body>
</html>
