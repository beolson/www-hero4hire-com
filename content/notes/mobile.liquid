---

pagination:
  data: collections.articles
  size: 6
  alias: mobile
layout: notes/base.liquid
title: Hero4Hire
---
<div>
  <div class="relative z-50 lg:hidden" role="dialog" aria-modal="true">
    <div class="fixed inset-0 bg-gray-900/80"></div>
    <div class="fixed inset-0 flex">
      <div class="relative mr-16 flex w-full max-w-xs flex-1">
        <div class="absolute left-full top-0 flex w-16 justify-center pt-5">
          <button type="button" class="-m-2.5 p-2.5">
            <span class="sr-only">Close sidebar</span>
            <svg
              class="h-6 w-6 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Sidebar component, swap this element with another sidebar if you like -->
        {% include 'notes/leftMenu' %}
      </div>
    </div>
  </div>

  <!-- Static sidebar for desktop -->
  <div class="hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex  lg:flex-col bg-slate-800">
    <!-- Sidebar component, swap this element with another sidebar if you like -->
    <div class=" text-slate-300 self-center text-xl font-bold py-2">Hero4Hire</div>
    {% include 'notes/leftMenu' %}
  </div>

  <div class="sticky top-0 z-40 flex items-center gap-x-6 bg-slate-700 px-4 py-4 shadow-sm sm:px-6 lg:hidden">
    <button type="button" class="-m-2.5 p-2.5 text-slate-300 lg:hidden">
      <span class="sr-only">Open sidebar</span>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
    <div class="flex-1 text-xl font-semibold leading-6 text-slate-300">Notes</div>
  </div>

  <main class="lg:pl-80 ">
    <div class="flex-grow m-6">
      <!-- Main area -->
      {% include 'notes/content' %}
    </div>
  </main>
</div>
