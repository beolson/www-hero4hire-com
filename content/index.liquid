---

pagination:
  data: collections.articles
  size: 6
  alias: articles
layout: layout.html
title: Hero4Hire
---
<div class="py-8">
  {%- for entry in articles %}
    <div class="container w-full md:max-w-5xl mx-auto pt-5">
      <div class="w-full px-4 md:px-6 text-xl text-gray-800 leading-normal">
        <div class="font-sans">
          <h1 class="font-bold font-sans break-normal text-gray-900 pt-6 pb-2 text-3xl md:text-4xl">
            <a href="{{ entry.url }}">{{ entry.data.title }}</a>
          </h1>
          <p class="text-sm md:text-base font-normal text-gray-600">Published {{ entry.date | htmlDateString }}</p>
          <div class="text-base md:text-sm text-gray-500 py-2">
            Tags:

            {%- for tag in entry.data.tags %}
              <a href="/tags/{{- tag -}}" class="text-base md:text-sm text-green-500 no-underline hover:underline">
                {{- tag -}}
              </a>
              {%- if forloop.last != true -%}&nbsp/{%- endif %}
            {%- endfor %}
          </div>
          <p>
            {{ entry.data.excerpt }}
          </p>
        </div>
      </div>
    </div>
  {%- endfor -%}

  <nav class="mt-10 flex items-center justify-between border-t border-gray-200 px-4 sm:px-0 container w-full md:max-w-5xl mx-auto ">
    {%- if page.url != pagination.href.first -%}
      <div class="-mt-px flex w-0 flex-1">
        <a
          href="{{ pagination.href.previous }}"
          class="inline-flex items-center border-t-2 border-transparent pr-1 pt-4 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700"
        >
          <svg class="mr-3 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10a.75.75 0 01-.75.75H4.66l2.1 1.95a.75.75 0 11-1.02 1.1l-3.5-3.25a.75.75 0 010-1.1l3.5-3.25a.75.75 0 111.02 1.1l-2.1 1.95h12.59A.75.75 0 0118 10z" clip-rule="evenodd" />
          </svg>
          Previous
        </a>
      </div>
    {%- endif %}
    {%- if page.url != pagination.href.last -%}
      <div class="-mt-px flex w-0 flex-1 justify-end">
        <a
          href="{{ pagination.href.next }}"
          class="inline-flex items-center border-t-2 border-transparent pl-1 pt-4 text-sm font-medium text-gray-500 hover:border-gray-300 hover:text-gray-700"
        >
          Next
          <svg class="ml-3 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M2 10a.75.75 0 01.75-.75h12.59l-2.1-1.95a.75.75 0 111.02-1.1l3.5 3.25a.75.75 0 010 1.1l-3.5 3.25a.75.75 0 11-1.02-1.1l2.1-1.95H2.75A.75.75 0 012 10z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    {%- endif %}
  </nav>
</div>
